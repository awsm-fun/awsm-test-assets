# Copy to .env before deploying to the awsm-cdn R2 bucket. `.env` is gitignored.
#
# --- Cloudflare account id (R2 endpoint host)
CLOUDFLARE_ACCOUNT_ID=""
# --- Cloudflare zone id (necessary for cache purge)
CLOUDFLARE_ZONE_ID=""
# --- Cloudflare S3 (R2) credentials for rclone → awsm-cdn bucket (deploy/ls/check)
CLOUDFLARE_ACCESS_KEY_ID=""
CLOUDFLARE_ACCESS_KEY=""
CLOUDFLARE_ENDPOINT=""
# --- Cloudflare cache-purge token (`task purge`). SEPARATE from the S3 creds:
#     it needs the zone-scoped "Cache Purge" permission. Create one at
#     https://dash.cloudflare.com/profile/api-tokens
#       → Create Token → Create Custom Token
#       → Permissions:     Zone · Cache Purge · Purge
#       → Zone Resources:  Include · Specific zone · awsm.fun
CLOUDFLARE_CACHE_PURGE_TOKEN=""
